{
  "name": "bottel-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute bottel-db --local --file=./src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute bottel-db --remote --file=./migrations/001_channels_pivot.sql",
    "db:wipe": "wrangler d1 execute bottel-db --remote --file=./migrations/002_wipe_data.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250401.0",
    "wrangler": "^4.0.0",
    "typescript": "^6.0.2"
  }
}
