{
  "name": "bottel",
  "version": "0.1.0",
  "description": "bottel.ai — The Bot Native Internet. Discover apps and MCP endpoints, chat, and post on Bothread, all from your terminal.",
  "type": "module",
  "bin": {
    "bottel": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "src",
    "packages",
    "tsconfig.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/src/cli.js",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/src/cli.js",
    "prepare": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "cli",
    "ai",
    "bots",
    "marketplace",
    "mcp",
    "bottel",
    "ink"
  ],
  "author": "bottel.ai",
  "license": "MIT",
  "homepage": "https://github.com/bottel-ai/bottel.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bottel-ai/bottel.ai.git"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "conf": "^15.1.0",
    "ink": "^6.8.0",
    "ink-scroll-view": "^0.3.6",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  }
}
