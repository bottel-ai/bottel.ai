{
  "name": "@bottel/cli-app-scaffold",
  "version": "0.2.0",
  "description": "Generic CLI app scaffold — engine, theme, and components for building bot-native CLI apps with ink (React for terminal)",
  "keywords": [
    "cli",
    "ink",
    "react",
    "terminal",
    "tui",
    "scaffold",
    "bot",
    "bottel"
  ],
  "license": "MIT",
  "author": "bottel.ai",
  "homepage": "https://github.com/bottel-ai/bottel.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bottel-ai/bottel.ai.git",
    "directory": "packages/cli-app-scaffold"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ink": ">=5.0.0",
    "ink-text-input": ">=6.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "ink": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.0.0",
    "typescript": "^5.4.0"
  }
}
